# ==============================================================================
# FESTORYX PLATFORM ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit the '.env' file to version control.
# ==============================================================================

# ─── DATABASE SETTINGS ────────────────────────────────────────────────────────
# DATABASE_URL: Connection URL for Prisma. If using a hosted database like Supabase,
# this should point to the pooled connection string (port 6543) with '?pgbouncer=true'.
# Direct URL is used by Prisma for running migrations and must bypass any pooler (port 5432).
#
# For Local Dev: Set up a local PostgreSQL instance and use direct connection.
DATABASE_URL="postgresql://postgres:password@localhost:5432/festoryx?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@localhost:5432/festoryx"

# For Production (Supabase Example):
# DATABASE_URL="postgresql://postgres.[username]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[username]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── APP IDENTITY & ROUTING ───────────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL: The base URL of the Web client (no trailing slash).
# Used for building absolute callback URLs and social sharing metadata.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Festoryx"

# ─── CLERK AUTHENTICATION ─────────────────────────────────────────────────────
# Credentials from Clerk Dashboard (https://dashboard.clerk.com).
# Sign up, create an application, and paste your publishable and secret keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk internal route configuration (leave defaults unless customizing Clerk pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ─── EMAIL SERVICE (SMTP) ─────────────────────────────────────────────────────
# Nodemailer SMTP settings. 
# For Gmail: Use 'smtp.gmail.com', port '587', and set SMTP_PASSWORD to a Google App Password
# generated from your Google Account settings (Security -> 2-Step Verification -> App Passwords).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_EMAIL="your-email@gmail.com"
SMTP_PASSWORD="your-google-app-password"
SMTP_FROM_NAME="Festoryx Team"

# ─── MEDIA CLOUD STORAGE (CLOUDINARY) ─────────────────────────────────────────
# Cloudinary settings for event banner uploads and payment proof screenshots.
# Retrieve these from your Cloudinary console dashboard (https://cloudinary.com).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ─── SUPER ADMIN PRIVILEGES ──────────────────────────────────────────────────
# SUPER_ADMIN_EMAIL: Logged-in Clerk users whose email matches this value are granted
# the role 'SUPER_ADMIN' in the database and gain full management privileges over
# all platform organizations, event submissions, and audit logs.
SUPER_ADMIN_EMAIL="your-super-admin@email.com"

# ─── QUIZ ARENA SYSTEM ────────────────────────────────────────────────────────
# NEXT_PUBLIC_SOCKET_URL: The endpoint of the Quiz WebSocket Relay server (usually port 3001).
# NEXT_PUBLIC_QUIZ_ARENA_URL: The base URL of the Quiz Frontend application (usually port 3002).
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
NEXT_PUBLIC_QUIZ_ARENA_URL="http://localhost:3002"

# ─── SESSION SECURITY ─────────────────────────────────────────────────────────
# SESSION_SECRET: A random 32-character string used to sign cookies and session data.
# Keep this secret secure and rotate periodically in production.
SESSION_SECRET="replace-with-a-32-character-session-secret"
