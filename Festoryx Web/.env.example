# ─── Database ───
# For local development, use a local PostgreSQL database
DATABASE_URL="postgresql://postgres:password@localhost:5432/festoryx?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@localhost:5432/festoryx"

# For production (Supabase), use connection pooling:
# DATABASE_URL="postgresql://postgres.[username]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[username]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── App Identity ───
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Festoryx"

# ─── Clerk Authentication ───
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ─── Email (Nodemailer + SMTP) ───
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_EMAIL="your-email@gmail.com"
SMTP_PASSWORD="your-google-app-password"
SMTP_FROM_NAME="Festoryx Team"

# ─── Cloudinary (Media Storage) ───
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ─── Super Admin ───
SUPER_ADMIN_EMAIL="your-super-admin@email.com"

# ─── Quiz Arena ───
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
NEXT_PUBLIC_QUIZ_ARENA_URL="http://localhost:3002"

# ─── Session Secret ───
SESSION_SECRET="replace-with-a-32-character-session-secret"
